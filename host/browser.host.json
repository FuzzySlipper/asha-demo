{
  "kind": "asha_demo.host_config.v1",
  "mode": "browser_served",
  "projectBundle": "project/project-bundle.json",
  "contentRoot": ".",
  "runtimeProvider": {
    "kind": "native_runtime_bridge_provider",
    "injection": "globalThis.ashaRuntimeBridge",
    "alias": "globalThis.ashaDemoRuntimeBridge",
    "required": true,
    "referenceFallback": false
  },
  "gameplayHost": {
    "kind": "static_gameplay_runtime_host",
    "moduleId": "demo.primary-fire-effect",
    "nativeBinding": "dist/native/asha-demo-gameplay-host.node",
    "projectBindings": "project/project-bundle.json"
  },
  "renderSurface": {
    "owner": "@asha/renderer-host",
    "backend": "host_private"
  },
  "launch": {
    "command": "npm run dev",
    "portPolicy": "native_browser_host_default_0_0_0_0_or_broker_owned",
    "hostPackage": "@asha/browser-host",
    "compatibilityVersion": "browser-host.v0"
  }
}
