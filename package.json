{
  "name": "asha-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Human-facing ASHA playable-loop demo built on public ASHA surfaces.",
  "scripts": {
    "build": "node scripts/build-native-provider.mjs && node scripts/build-ui.mjs",
    "build:native-provider": "node scripts/build-native-provider.mjs",
    "capture:replay": "node scripts/capture-replay-evidence.mjs",
    "check:architecture": "node scripts/check-source-architecture.mjs",
    "check:content-boundary": "node scripts/build-ui.mjs && node scripts/check-content-boundary.mjs",
    "check:demo-rs": "cargo run -q --manifest-path demo-rs/Cargo.toml --bin asha-demo-preflight -- .",
    "check:gameplay-module": "cargo run -q --manifest-path demo-rs/Cargo.toml --bin asha-demo-gameplay-conformance -- artifacts/5636/gameplay-module-conformance.json",
    "check:dependencies": "node scripts/check-dependency-boundary.mjs",
    "check:host": "node scripts/check-host-parity.mjs",
    "check:replay": "node scripts/capture-replay-evidence.mjs",
    "check:standalone": "node scripts/standalone-host.mjs",
    "check:strict-boundary": "tsc -p tsconfig.strict-boundary.json",
    "check:ui": "node scripts/check-ui-assets.mjs",
    "dev": "node scripts/serve-ui.mjs",
    "dev:static": "node scripts/serve-static-ui.mjs",
    "skeleton:status": "node scripts/print-skeleton-status.mjs",
    "standalone": "node scripts/standalone-host.mjs",
    "test:live-ui": "playwright test -c playwright.config.mjs",
    "typecheck": "npm run check:dependencies && npm run check:architecture && npm run check:strict-boundary && npm run check:content-boundary && npm run check:demo-rs && npm run check:gameplay-module && npm run check:host && npm run check:ui && npm run check:standalone && npm run check:replay",
    "test": "npm run typecheck"
  },
  "dependencies": {
    "@asha/catalog-core": "file:../asha-engine/ts/packages/catalog-core",
    "@asha/browser-host": "file:../asha-engine/ts/packages/browser-host",
    "@asha/contracts": "file:../asha-engine/ts/packages/contracts",
    "@asha/game-workspace": "file:../asha-engine/ts/packages/game-workspace",
    "@asha/render-projection": "file:../asha-engine/ts/packages/render-projection",
    "@asha/renderer-host": "file:../asha-engine/ts/packages/renderer-host",
    "@asha/runtime-bridge": "file:../asha-engine/ts/packages/runtime-bridge",
    "@asha/runtime-session": "file:../asha-engine/ts/packages/runtime-session",
    "@asha/ui-dom": "file:../asha-engine/ts/packages/ui-dom"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^6.0.3"
  }
}
